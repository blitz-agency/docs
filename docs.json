{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BlitzAPI - The API Engine for every GTM Playbook",
  "description": "High-performance B2B data infrastructure for Growth & Revenue teams. Waterfall ICP Search, Email & Phone Enrichment, and Company Search APIs.",
  "colors": {
    "primary": "#0055FE",
    "light": "#F8FAFC",
    "dark": "#0F172A"
  },
  "favicon": "/favicon.svg",
  "api":{
    "examples":{
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "global": {
      "anchors": []
    },
    "tabs": [
      {
        "tab": "Guide",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index",
              "guide/concepts/pricing-unlimited"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "guide/getting-started/authentication",
              "guide/getting-started/quickstart",
              "guide/getting-started/code-examples"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "guide/concepts/waterfall-logic",
              "guide/concepts/employee-finder",
              "guide/concepts/quality",
              "guide/concepts/company-search"
            ]
          },
          {
            "group": "Recipes (Use Cases)",
            "pages": [
              "guide/recipes/enrichment-workflow",
              "guide/recipes/crm-hygiene"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "guide/integrations/clay",
              "guide/integrations/n8n",
              "guide/integrations/make",
              "guide/integrations/MCP"
            ]
          },
          {
            "group": "Appendix",
            "pages": [
              "guide/reference/appendix",
              "guide/reference/field-normalization"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "versions": [
          {
            "version": "v2",
            "openapi": "api-reference/v2.openapi.json"
          },
          {
            "version": "v1",
            "openapi": "api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/blitz.png",
    "dark": "/logo/logo-blitz-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Pricing",
        "href": "https://blitz-api.ai/pricing"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Book a demo",
      "href": "https://cal.com/antoine-blitz-acepmu/blitz-api"
    }
  },
  "footer": {
    "socials": {
      "youtube": "https://www.youtube.com/@BlitzAPI",
      "linkedin": "https://www.linkedin.com/company/blitz-api/"
    },
    "links": [
      {
        "header": "Resources",
        "items": [
          {
            "label": "Pricing",
            "href": "https://blitz-api.ai/pricing"
          },
          {
            "label": "API Status",
            "href": "https://blitz-api.ai/status"
          },
          {
            "label": "Book a Demo",
            "href": "https://cal.com/antoine-blitz-acepmu/blitz-api"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "Dashboard",
            "href": "https://app.blitz-api.ai"
          },
          {
            "label": "LinkedIn",
            "href": "https://www.linkedin.com/company/blitz-api/"
          },
          {
            "label": "YouTube",
            "href": "https://www.youtube.com/@BlitzAPI"
          }
        ]
      }
    ]
  },
  "integrations": {
    "telemetry": {
      "enabled": true
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Page not found",
      "description": "This page doesn't exist. Check the URL or navigate using the sidebar."
    }
  }
}